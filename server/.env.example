# Backend config (copy to .env)
PORT=4000

# Gates /settings writes + config POST. Use a long random string in prod.
OWNER_KEY=dev-owner-key

# Tracked channels (comma-separated). Use big LIVE channels for the demo so chat flows.
TWITCH_CHANNELS=ansem
KICK_CHANNELS=xqc
X_TARGETS=

# X (Playwright) — persistent logged-in profile dir. Leave X_TARGETS empty to disable X.
X_USER_DATA_DIR=
